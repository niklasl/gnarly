PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX : <http://example.net/ns/>
BASE <https://example.org/>

<1> a :Person ;
  :topic_interest :Q12418 {| a :Interest ;
        :date "1998-10-04"^^:date |}
    {| a :Statement ;
        :date "2004-01-12"^^:date ; :source <x> |} .

<a> a :Thing ;
    :name "A" ;
    :value "v", :V, <v>, [ a :V ] ;
    :references <b> , <x> , _:y, : .

_:y a :Thing ;
    :value 1, 1.2, 2.34e0, true ;
    :references [ :name "z" ] .

<b> a :Thing .

<c> a :Collection ;
    :items (1 [ :name "Two" ] ) ;
    :items (1 <b> <c> [ :name "Three" ] <d> <e> ) .

<d> a :Thing ;
    :name "Third" {| :source <one> |} ~ <namednote> ~ <f> ~ _:g ~ _:empty  ,
        "Fourth" {| :source <other> |} ~ <namednote>  ,
        "Fifth" ~ <one> ~ <namednote> ~ <f> ~ _:g ~ _:empty  .

<e> a :Thing ;
    :references [ a :Some ; :name "some" ] .

<< <a> :name "B" >> a :Claim .

<< <a> :name "B "~ <claim> >> a :Claim .

<< <a> :name "C" ~ <f> >> a :Claim .
<< <a> :name "D" ~ <f> >> .

<< <a> :name "G" ~ _:g >> .

<u> a [ :label "Unknown" ] .

_:blank a :Thing .

[] a :Thing .

_:z a :Thing ; :self _:z .

_:z0 a :Thing ; :rel [ :rel _:z0 ] .

() a :Oddity .
(0 9) a :Oddity .
(<a> <b> <c> <d> (<a> <b> <c> <d>)) a :Oddity .

<xyz>
  a 123 {| :note "ill-typed" |} ,
    :Monograph {| :note "annnoted-type" |} ,
    <<( <xyz> rdf:reifies rdf:type )>> ;
  rdf:reifies rdf:type .

graph <g1> {

  <1> a :Person ;
    :topic_interest :Q12418 .

  <a> a :Thing ;
    :name "A" ~ <a> .

}
